{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gate Criteria Config",
  "description": "Schema for .specify/gates/tr-criteria.yml — gate criteria definitions with phase ownership",
  "type": "object",
  "required": ["gate_criteria"],
  "properties": {
    "gate_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "gate", "type", "title", "owning_phase", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TR\\d+(_TR\\d+)?-(MM|SM)-\\d{3}$",
            "description": "Sequential ID: TR{Gate}-{MM|SM}-{NNN}, e.g. TR2-MM-001"
          },
          "gate": {
            "type": "string",
            "description": "Gate identifier, e.g. TR2/TR3",
            "examples": ["TR2/TR3", "TR4", "TR5"]
          },
          "type": {
            "type": "string",
            "enum": ["Must-Meet", "Should-Meet"],
            "description": "Must-Meet is a veto criterion; Should-Meet is a scorecard criterion"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Short human-readable title"
          },
          "owning_phase": {
            "type": "string",
            "enum": ["Plan", "Task", "Implementation"],
            "description": "Phase that produces this criterion's evidence"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Detailed description of the criterion"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^TR\\d+(_TR\\d+)?-(MM|SM)-\\d{3}$"
            },
            "description": "List of criterion IDs that should be evaluated before this one"
          },
          "validation_hint": {
            "type": "string",
            "description": "Guidance for how to validate this criterion at review"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
