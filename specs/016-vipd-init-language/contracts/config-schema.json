{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VIPD Config",
  "description": "Schema for .vipd/config.yml — project-level vipd configuration",
  "type": "object",
  "properties": {
    "language": {
      "type": "string",
      "description": "Language code for vipd CLI output",
      "minLength": 2,
      "maxLength": 10,
      "examples": ["en", "zh", "ja"]
    }
  },
  "additionalProperties": true
}
